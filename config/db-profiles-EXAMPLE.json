{
    "default_profile": "postgres",
    "profiles": {
        "postgres": { "1psa_or_env_item": "LOCALHOST_POSTGRES_TELLER" },
        "supabase": { "1psa_or_env_item": "EGGNEST_SUPABASE" },
        "supabase_direct": { "1psa_or_env_item": "EGGNEST_SUPABASE_DIRECT" },
        "sqlite": {
            "1psa_or_env_item": "LOCALHOST_SQLITE_TELLER",
            "sqlcipher_key_field": "sqlcipher_key"
        }
    }
}
