# Runbook profile: eggnest "run all test runners" meta-run.
#
# Reuses the parallel-orchestrator golden (07_run_all_tests_parallel.sh) in runners-discovery mode.
# Each lane is one repo's canonical run-all pointer, discovered shallowly from the eggnest root
# (`find . -maxdepth 2 -name '[0-9][0-9]_run_all_*tests_parallel.sh' -type f -perm -u=x`): the five
# subrepos plus eggnest's own 03_ self-run. The golden's SELF_SCRIPT_BASENAME guard drops the golden
# engine itself (runner/07_run_all_tests_parallel.sh), so runner is represented by its
# 08_run_all_self_tests_parallel.sh self-run pointer. No hardcoded list of runners.

# --- venv/prereq knobs are irrelevant here: the meta-run only orchestrates child runners. ---
VENV_EXISTS_POLICY="exit"
REQUIRE_PREREQ_SCRIPT="false"

# --- orchestrator: runners-discovery mode. ---
PARALLEL_CHECKS_RUNNERS_MODE="true"
# Keep meta-run artifacts out of eggnest's own 03_ self-run report dir (both resolve to the eggnest root).
PARALLEL_CHECKS_REPORT_DIR="./artifacts/runners-parallel"

export VENV_EXISTS_POLICY REQUIRE_PREREQ_SCRIPT \
  PARALLEL_CHECKS_RUNNERS_MODE PARALLEL_CHECKS_REPORT_DIR
