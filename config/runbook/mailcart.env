# Runbook profile: mailcart (native Swift/macOS app; Outlook Graph integration).

# --- 01_install_prerequisites (install: Xcode/Swift toolchain + 1psa + SAST hook) ---
PREREQ_MODE="install"
PREREQ_BANNER="Prerequisites Installer"
BREW_FORMULAS="xcodegen mkcert"
PREREQ_ENABLE_XCODE="false"
PREREQ_ENABLE_XCODE_TOOLCHAIN="true"
PREREQ_ENABLE_XCODE_FIRST_LAUNCH="true"
PREREQ_ENABLE_SWIFT="true"
PREREQ_ENABLE_ZAP="false"
PREREQ_ENABLE_PG_INSTALL="false"
PREREQ_ENABLE_PGTAP="false"
PREREQ_ENABLE_1PSA="true"
PREREQ_1PSA_SUDO_VIA_1PSA="false"
PREREQ_EXTRA_HOOK="src/scripts/prereq_hooks/mailcart_swift_sast.sh"
OUTLOOK_GRAPH_TOKEN_PSA_ITEM="${OUTLOOK_GRAPH_TOKEN_PSA_ITEM:-OUTLOOK_GRAPH_API}"
OUTLOOK_GRAPH_TOKEN_PSA_FIELD="${OUTLOOK_GRAPH_TOKEN_PSA_FIELD:-token}"
PREREQ_FINAL_GUIDANCE="✅ All prerequisites are satisfied for this repository.

Next commands:
- make build
- make sast
- make test
- make ui-test
- make run
- ./04_install_matchy_api_tls.sh

1psa defaults for real Outlook token:
- item: ${OUTLOOK_GRAPH_TOKEN_PSA_ITEM}
- field: ${OUTLOOK_GRAPH_TOKEN_PSA_FIELD}"

# --- 02_create_venv ---
VENV_EXISTS_POLICY="exit"
INSTALL_VENV_TEST_CACHE="false"
ACTIVATION_HINT="activate"
REQUIRE_PREREQ_SCRIPT="true"

# --- 04_install_matchy_api_tls: knobs for the generic install_api_tls golden (legacy MAILCART_MATCHY_TLS_* honored). ---
API_TLS_LABEL="Matchy-compatible Mailcart API"
API_TLS_DIR="${MAILCART_MATCHY_TLS_DIR:-$HOME/.mailcart}"
API_TLS_CERT_FILE="${MAILCART_MATCHY_TLS_CERT_FILE:-${API_TLS_DIR}/matchy-localhost-cert.pem}"
API_TLS_KEY_FILE="${MAILCART_MATCHY_TLS_KEY_FILE:-${API_TLS_DIR}/matchy-localhost-key.pem}"
API_TLS_FORCE_REGENERATE="${MAILCART_MATCHY_TLS_FORCE_REGENERATE:-false}"

# --- 03_load_requirements (locked golden in repo; wrapper sets knobs) ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="false"
LOAD_REQUIREMENTS_PIP_UPGRADE="true"

# --- unit/orchestrator defaults for runner/tests wrappers ---
PYTEST_DIR="tests/python"
ORCHESTRATOR_MODE="parallel-discover"
# Mailcart-specific quality lane map (mailcart's local lane numbering t00-t10):
# - The teller-only/classy-only lanes (DB deploy/SQL/API smoke/canary, Swift/macOS UI)
#   are not present in mailcart and are intentionally excluded.
# - Includes mailcart-supported quality lanes including mutation/fuzz/DAST (t07/t08/t09).
QUALITY_LANE_GROUPS='{"behavioral_coverage":["t04_run_requirements_traceability_tests","t05_run_shell_unit_tests"],"effectiveness_quality":["t00_run_code_quality_tests","t06_run_python_unit_tests","t07_run_mutation_tests","t08_run_fuzz_tests"],"security_runtime_quality":["t01_run_av_test","t02_run_dependency_freshness_tests","t03_run_static_security_tests","t09_run_dynamic_security_tests","t10_verify_filevault_encryption_test"]}'
# Mutation + fuzz lane knobs for mailcart's Python surface.
MUTATION_SCORE_THRESHOLD="0"
MUTATOR_COVERAGE_THRESHOLD="0"
FUZZ_TEST_PATHS="tests/python/test_matchy_mailcart_api_fuzz.py"
FUZZ_MAX_EXAMPLES="100"
FUZZ_MIN_TOTAL_EXAMPLES="360"
# Dynamic security lane knobs: run against mailcart's own HTTPS app wrapper and
# skip teller-specific DB/token/ZAP assumptions.
DAST_APP_SCRIPT="dast_app.py"
DAST_DB_INTEGRATION="false"
DAST_REQUIRE_WRITE_TOKEN="false"
RUN_ZAP="false"
RUN_SCHEMATHESIS="false"
STRICT_TRACEABILITY_FULL_COVERAGE="false"
STRICT_TRACEABILITY_NUMBERED_TAGS="false"
STRICT_TRACEABILITY_NUMBERED_BULLETS="false"
# shared pointer-contract requirements + bats are centralized in runner.
TRACEABILITY_REQUIREMENTS_ROOTS="${RUNBOOK_REPO_ROOT}/requirements:${RUNNER_HOME}/shared/requirements/pointers/mailcart"
TRACEABILITY_TEST_ROOTS="${RUNBOOK_REPO_ROOT}/tests/sh:${RUNNER_HOME}/shared/tests/sh/pointers/mailcart"
SHELL_BATS_ROOTS="${TRACEABILITY_TEST_ROOTS}"

export PREREQ_MODE PREREQ_BANNER BREW_FORMULAS PREREQ_ENABLE_XCODE PREREQ_ENABLE_XCODE_TOOLCHAIN \
  PREREQ_ENABLE_XCODE_FIRST_LAUNCH PREREQ_ENABLE_SWIFT PREREQ_ENABLE_ZAP \
  PREREQ_ENABLE_PG_INSTALL PREREQ_ENABLE_PGTAP PREREQ_ENABLE_1PSA \
  PREREQ_1PSA_SUDO_VIA_1PSA PREREQ_EXTRA_HOOK OUTLOOK_GRAPH_TOKEN_PSA_ITEM \
  OUTLOOK_GRAPH_TOKEN_PSA_FIELD PREREQ_FINAL_GUIDANCE VENV_EXISTS_POLICY \
  INSTALL_VENV_TEST_CACHE ACTIVATION_HINT REQUIRE_PREREQ_SCRIPT \
  API_TLS_LABEL API_TLS_DIR API_TLS_CERT_FILE API_TLS_KEY_FILE API_TLS_FORCE_REGENERATE \
  LOAD_REQUIREMENTS_BOOTSTRAP_PIP LOAD_REQUIREMENTS_PIP_UPGRADE \
  PYTEST_DIR ORCHESTRATOR_MODE QUALITY_LANE_GROUPS \
  MUTATION_SCORE_THRESHOLD MUTATOR_COVERAGE_THRESHOLD FUZZ_TEST_PATHS FUZZ_MAX_EXAMPLES FUZZ_MIN_TOTAL_EXAMPLES \
  DAST_APP_SCRIPT DAST_DB_INTEGRATION DAST_REQUIRE_WRITE_TOKEN RUN_ZAP RUN_SCHEMATHESIS \
  STRICT_TRACEABILITY_FULL_COVERAGE STRICT_TRACEABILITY_NUMBERED_TAGS STRICT_TRACEABILITY_NUMBERED_BULLETS \
  TRACEABILITY_REQUIREMENTS_ROOTS TRACEABILITY_TEST_ROOTS SHELL_BATS_ROOTS
