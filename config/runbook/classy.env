# Runbook profile: classy (verify-only prereqs; classifier API + macOS UI; depends on teller).

# --- 01_install_prerequisites (verify-only, no Homebrew installs) ---
PREREQ_MODE="verify"
PREREQ_BANNER="Checking classy prerequisites"
PREREQ_VERIFY_COMMANDS="python3.12|python3.12 (or python3)
swift|swift (Xcode command line tools)
mkcert|mkcert (brew install mkcert) for local classifier API TLS
1psa|1psa (1Password CLI shim) for CLASSY_WRITE_TOKEN + DB password
sqlcipher|sqlcipher (brew install sqlcipher) for pysqlcipher3"
PREREQ_VERIFY_SQLCIPHER_HEADERS="true"
PREREQ_SUCCESS_GUIDANCE="Next: ./02_create_venv.sh && source classy-venv/bin/activate && ./03_load_requirements.sh"
PREREQ_FINAL_GUIDANCE="Next: ./02_create_venv.sh && source classy-venv/bin/activate && ./03_load_requirements.sh
  ./05_install_classifier_api_tls.sh"

# --- 02_create_venv ---
VENV_EXISTS_POLICY="continue"
INSTALL_VENV_TEST_CACHE="true"
ACTIVATION_HINT="activate"
REQUIRE_PREREQ_SCRIPT="true"

# --- 03_load_requirements (classy wrapper: SQLCipher build + editable teller, requirements.in fallback) ---
LOAD_REQUIREMENTS_FILES="requirements.txt requirements.in"
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="false"
LOAD_REQUIREMENTS_SQLCIPHER_BUILD="true"
LOAD_REQUIREMENTS_EDITABLE_SIBLINGS="${CLASSY_TELLER_DIR:-../teller}"

# --- orchestrator 08_run_all_tests_parallel (parallel autodiscovery of tests/t*.sh pointers) ---
# Lanes are discovered from tests/ (no hardcoded list), so renames/renumbers just work.
# TEST_POINTER_PREFIX is empty because classy's tests/tNN_ files are themselves the pointers.
ORCHESTRATOR_MODE="parallel-discover"
TEST_POINTER_PREFIX=""
# Quality scoring/telemetry not needed in classy yet (deferred to a later refactor).
QUALITY_SCORING_ENABLED="false"
# DAST (t12): classy's classifier API entrypoint + skip teller-DB seeding/integrity sub-steps.
DAST_APP_SCRIPT="06_run_classification_api.py"
DAST_DB_INTEGRATION="false"
WRITE_TOKEN_PSA_ITEM="CLASSY_WRITE_TOKEN"
WRITE_TOKEN_HEADER_NAME="X-Classy-Write-Token"
# t00: ignore pydantic validator receiver `cls` (vulture false-positive on @field_validator classmethods).
VULTURE_EXTRA_ARGS="--ignore-names cls"
# t11 fuzz: classy property tests use smaller per-test example counts than teller's defaults.
FUZZ_MIN_PER_TEST_RATIO_PERCENT="10"
FUZZ_MIN_TOTAL_EXAMPLES="1500"
# t02: classy pins direct deps in requirements.in (no generated requirements.txt).
DEPENDENCY_REQUIREMENTS_FILE="requirements.in"
# t02: teller is installed editable (sibling dependency), intentional non-cruft.
DEPENDENCY_VENV_CRUFT_ALLOW="teller"

export PREREQ_MODE PREREQ_BANNER PREREQ_VERIFY_COMMANDS PREREQ_VERIFY_SQLCIPHER_HEADERS \
  PREREQ_SUCCESS_GUIDANCE PREREQ_FINAL_GUIDANCE VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT \
  REQUIRE_PREREQ_SCRIPT LOAD_REQUIREMENTS_FILES LOAD_REQUIREMENTS_BOOTSTRAP_PIP \
  LOAD_REQUIREMENTS_SQLCIPHER_BUILD LOAD_REQUIREMENTS_EDITABLE_SIBLINGS \
  ORCHESTRATOR_MODE TEST_POINTER_PREFIX QUALITY_SCORING_ENABLED DAST_APP_SCRIPT DAST_DB_INTEGRATION \
  WRITE_TOKEN_PSA_ITEM WRITE_TOKEN_HEADER_NAME VULTURE_EXTRA_ARGS FUZZ_MIN_PER_TEST_RATIO_PERCENT FUZZ_MIN_TOTAL_EXAMPLES \
  DEPENDENCY_REQUIREMENTS_FILE DEPENDENCY_VENV_CRUFT_ALLOW
