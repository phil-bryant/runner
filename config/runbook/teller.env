# Runbook profile: teller (full stack: Postgres, pgTAP, ZAP, Xcode, 1psa).
# Sourced by teller/rNN_*.sh thin pointers before exec of the runner golden.

# --- 01_install_prerequisites ---
PREREQ_MODE="install"
PREREQ_BANNER="Prerequisites Installer"
BREW_FORMULAS="go git swiftlint shellcheck gitleaks bats-core:bats clamav:clamscan perl cpanminus:cpanm mkcert peripheryapp/periphery/periphery:periphery pip-tools:pip-compile sqlcipher:sqlcipher cosign:cosign"
PREREQ_ENABLE_ZAP="true"
PREREQ_ENABLE_1PSA="true"
PREREQ_1PSA_ADVISORY="false"
PREREQ_ENABLE_XCODE="true"
PREREQ_ENABLE_PG_INSTALL="true"
PREREQ_ENABLE_PGTAP="true"

# --- 02_create_venv ---
VENV_EXISTS_POLICY="continue"
INSTALL_VENV_TEST_CACHE="true"
ACTIVATION_HINT="activate"
REQUIRE_PREREQ_SCRIPT="true"

# --- 04_load_requirements (locked golden; wrapper sets knobs) ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="true"
BOOTSTRAP_PIP_VERSION="26.1.2"
BOOTSTRAP_PIP_SHA256="382ff9f685ee3bc25864f820aa50505825f10f5458ffff07e30a6d96e5715cab"  # pragma: allowlist secret

# --- orchestrator 07_run_all_tests_parallel (discover and run teller tests/tNN_ pointers) ---
ORCHESTRATOR_MODE="parallel-discover"
# Quality scoring ON; teller has extra lanes beyond the default compact t00-t10 map.
QUALITY_LANE_GROUPS='{"behavioral_coverage":["t05_deploy_database_verification_test","t12_run_teller_api_smoke_tests"],"effectiveness_quality":["t00_run_code_quality_tests","t06_run_sql_unit_tests","t07_run_shell_unit_tests","t08_run_python_unit_tests","t09_run_mutation_tests","t10_run_fuzz_tests"],"security_runtime_quality":["t01_run_av_test","t02_run_dependency_freshness_tests","t03_run_static_security_tests","t11_run_dynamic_security_tests","t13_run_teller_live_canary_test","t14_verify_filevault_encryption_test"]}'
# DAST (t11): teller delegates classifier API security checks to classy's extracted API.
DAST_APP_SCRIPT="../classy/05_run_classification_api.py"
DAST_DB_INTEGRATION="false"
WRITE_TOKEN_PSA_ITEM="CLASSY_WRITE_TOKEN"
WRITE_TOKEN_HEADER_NAME="X-Classy-Write-Token"
RUNBOOK_PYTHONPATH="${RUNBOOK_REPO_ROOT}/src:${RUNBOOK_REPO_ROOT}/../classy/src"
if [[ -n "${PYTHONPATH:-}" ]]; then
  PYTHONPATH="${RUNBOOK_PYTHONPATH}:${PYTHONPATH}"
else
  PYTHONPATH="${RUNBOOK_PYTHONPATH}"
fi

export PREREQ_MODE PREREQ_BANNER BREW_FORMULAS PREREQ_ENABLE_ZAP PREREQ_ENABLE_1PSA \
  PREREQ_1PSA_ADVISORY PREREQ_ENABLE_XCODE PREREQ_ENABLE_PG_INSTALL PREREQ_ENABLE_PGTAP \
  VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT REQUIRE_PREREQ_SCRIPT \
  LOAD_REQUIREMENTS_BOOTSTRAP_PIP BOOTSTRAP_PIP_VERSION BOOTSTRAP_PIP_SHA256 ORCHESTRATOR_MODE QUALITY_LANE_GROUPS DAST_APP_SCRIPT \
  DAST_DB_INTEGRATION WRITE_TOKEN_PSA_ITEM WRITE_TOKEN_HEADER_NAME RUNBOOK_PYTHONPATH PYTHONPATH
