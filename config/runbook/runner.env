# Runbook profile: runner self-run (the engine running its own applicable lanes on itself).
# Sourced by runner/11_run_all_self_tests_parallel.sh before exec of the 07_run_all_tests_parallel.sh golden.
# Only the lanes that make sense for the engine repo run: av, dependency freshness, static security,
# requirements traceability, and shell unit tests. DB/Swift/DAST/UI lanes are intentionally absent.
# Selection is by RUN_LANE_ALLOWLIST (the orchestrator discovers tests/tNN_*.sh goldens directly; no rtNN_ pointers).

# --- 01_install_prerequisites (slim: shell/SAST/AV/python toolchain only) ---
PREREQ_MODE="install"
PREREQ_BANNER="Runner self-run prerequisites"
BREW_FORMULAS="shellcheck gitleaks clamav:clamscan semgrep bandit pip-audit detect-secrets ruff bats-core:bats kcov:kcov parallel"
PREREQ_ENABLE_ZAP="false"
PREREQ_ENABLE_1PSA="false"
PREREQ_1PSA_ADVISORY="true"
PREREQ_ENABLE_XCODE="false"
PREREQ_ENABLE_PG_INSTALL="false"
PREREQ_ENABLE_PGTAP="false"
PREREQ_FINAL_GUIDANCE="✅ Prerequisites complete."

# --- 02_create_venv ---
VENV_EXISTS_POLICY="continue"
INSTALL_VENV_TEST_CACHE="false"
ACTIVATION_HINT="activate"
REQUIRE_PREREQ_SCRIPT="false"

# --- 03/04_load_requirements (hash-pinned requirements.txt golden; enforce pinned secure pip bootstrap) ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="true"
LOAD_REQUIREMENTS_PIP_UPGRADE="false"
BOOTSTRAP_PIP_VERSION="26.1.2"
BOOTSTRAP_PIP_SHA256="382ff9f685ee3bc25864f820aa50505825f10f5458ffff07e30a6d96e5715cab"  # pragma: allowlist secret

# --- SAST targets: leave PYTHON_SRC_DIRS unset so bandit uses the engine default (tests/py; shared
# tooling under src/scripts is intentionally not scanned here, mirroring how every other repo profile
# treats runner-owned tooling copies). ---

# --- t02 dependency freshness: runner has no Postgres/teller-API/binary-integrity sub-lanes (applicability). ---
RUN_POSTGRES_FRESHNESS="false"
RUN_TELLER_VERSION_FRESHNESS="false"
RUN_BINARY_INTEGRITY_CHECK="false"

# --- t04 traceability: strictness is built in (no strictness env knobs supported). ---

# --- t07/t08 self-run tuning for the traceability engine. ---
MUTATION_SCORE_THRESHOLD="80"
MUTATOR_COVERAGE_THRESHOLD="75"
FUZZ_TEST_PATHS="tests/py/properties"
FUZZ_MIN_PROPERTY_TESTS="4"
FUZZ_MAX_EXAMPLES="100"
FUZZ_MIN_PER_TEST_RATIO_PERCENT="80"
RUN_SHELLCHECK_GATE="false"
SECURITY_FAIL_ON_MEDIUM_OR_HIGHER="false"

# --- orchestrator: discover runner's own tests/tNN_ goldens and run only the self-run allow-list. ---
ORCHESTRATOR_MODE="parallel-discover"
RUN_LANE_ALLOWLIST="t01_run_av_test t02_run_dependency_freshness_tests t03_run_static_security_tests t04_run_requirements_traceability_tests t05_run_shell_unit_tests t06_run_python_unit_tests t07_run_mutation_tests t08_run_fuzz_tests"

export PREREQ_MODE PREREQ_BANNER BREW_FORMULAS PREREQ_ENABLE_ZAP PREREQ_ENABLE_1PSA \
  PREREQ_1PSA_ADVISORY PREREQ_ENABLE_XCODE PREREQ_ENABLE_PG_INSTALL PREREQ_ENABLE_PGTAP \
  PREREQ_FINAL_GUIDANCE VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT \
  REQUIRE_PREREQ_SCRIPT LOAD_REQUIREMENTS_BOOTSTRAP_PIP LOAD_REQUIREMENTS_PIP_UPGRADE \
  BOOTSTRAP_PIP_VERSION BOOTSTRAP_PIP_SHA256 RUN_POSTGRES_FRESHNESS RUN_TELLER_VERSION_FRESHNESS \
  RUN_BINARY_INTEGRITY_CHECK MUTATION_SCORE_THRESHOLD MUTATOR_COVERAGE_THRESHOLD FUZZ_TEST_PATHS \
  FUZZ_MIN_PROPERTY_TESTS FUZZ_MAX_EXAMPLES FUZZ_MIN_PER_TEST_RATIO_PERCENT RUN_SHELLCHECK_GATE \
  SECURITY_FAIL_ON_MEDIUM_OR_HIGHER ORCHESTRATOR_MODE \
  RUN_LANE_ALLOWLIST
