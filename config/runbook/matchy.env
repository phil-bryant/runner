# Runbook profile: matchy (SAST/Python checks; no Postgres/Swift stacks).

# --- 01_install_prerequisites (install slim SAST/Python formula set) ---
PREREQ_MODE="install"
PREREQ_BANNER="Matchy prerequisites"
BREW_FORMULAS="shellcheck semgrep gitleaks detect-secrets ruff bandit pip-audit bats-core:bats parallel"
PREREQ_ENABLE_ZAP="true"
PREREQ_ENABLE_1PSA="false"
PREREQ_1PSA_ADVISORY="true"
PREREQ_ENABLE_XCODE="false"
PREREQ_ENABLE_PG_INSTALL="false"
PREREQ_ENABLE_PGTAP="false"
PREREQ_FINAL_GUIDANCE="✅ Prerequisites complete."

# --- 02_create_venv ---
VENV_EXISTS_POLICY="exit"
INSTALL_VENV_TEST_CACHE="false"
ACTIVATION_HINT="activate"
REQUIRE_PREREQ_SCRIPT="true"

# --- 03_load_requirements (locked golden in repo; wrapper sets knobs) ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="false"
LOAD_REQUIREMENTS_PIP_UPGRADE="true"

# --- unit / security / av lanes ---
PYTEST_DIR="tests/py"
PYTHON_SRC_DIRS="matchy"
BANDIT_EXCLUDES="./matchy-venv,./.venv,./build,./dist"

# --- orchestrator (discover tests/tNN_* wrappers) ---
ORCHESTRATOR_MODE="parallel-discover"
# matchy's Python package is top-level ./matchy (no ./src); drive quality + bandit targets explicitly (applicability).
QUALITY_TARGETS="./matchy ./tests/py"
# t06: Python line coverage policy for matchy unit-test lane.
RUN_PYTEST_COVERAGE="true"
COVERAGE_REPORT_DIR="./artifacts/coverage"
COVERAGE_SOURCE_DIRS="matchy"
# matchy is installed editable (intentional, not venv cruft).
DEPENDENCY_VENV_CRUFT_ALLOW="matchy"
# matchy's property-based fuzz target location (applicability; budget stays at the strict default).
FUZZ_TEST_PATHS="tests/py/test_scoring_properties.py"
# Curated, proven-equivalent mutmut mutants excluded from the mutation score (threshold stays 95%).
MUTATION_EQUIVALENTS_FILE="tests/mutation_equivalents.txt"
# --- DAST (t09): serve matchy's own FastAPI app; matchy's match API has no write-token auth (applicability). ---
DAST_APP_SCRIPT="dast_app.py"
DAST_DB_INTEGRATION="false"
DAST_REQUIRE_WRITE_TOKEN="false"
WRITE_TOKEN_HEADER_NAME="X-Matchy-Write-Token"
# shared pointer-contract requirements + bats are centralized in runner.
TRACEABILITY_REQUIREMENTS_ROOTS="${RUNBOOK_REPO_ROOT}/requirements:${RUNNER_HOME}/shared/requirements/pointers/matchy"
TRACEABILITY_TEST_ROOTS="${RUNBOOK_REPO_ROOT}/tests/sh:${RUNNER_HOME}/shared/tests/sh/pointers/matchy"
SHELL_BATS_ROOTS="${TRACEABILITY_TEST_ROOTS}"

export PREREQ_MODE PREREQ_BANNER BREW_FORMULAS PREREQ_ENABLE_ZAP PREREQ_ENABLE_1PSA \
  PREREQ_1PSA_ADVISORY PREREQ_ENABLE_XCODE PREREQ_ENABLE_PG_INSTALL PREREQ_ENABLE_PGTAP \
  PREREQ_FINAL_GUIDANCE VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT \
  REQUIRE_PREREQ_SCRIPT LOAD_REQUIREMENTS_BOOTSTRAP_PIP LOAD_REQUIREMENTS_PIP_UPGRADE \
  PYTEST_DIR PYTHON_SRC_DIRS BANDIT_EXCLUDES ORCHESTRATOR_MODE \
  QUALITY_TARGETS RUN_PYTEST_COVERAGE COVERAGE_REPORT_DIR COVERAGE_SOURCE_DIRS \
  DEPENDENCY_VENV_CRUFT_ALLOW FUZZ_TEST_PATHS \
  MUTATION_EQUIVALENTS_FILE DAST_APP_SCRIPT DAST_DB_INTEGRATION DAST_REQUIRE_WRITE_TOKEN WRITE_TOKEN_HEADER_NAME \
  TRACEABILITY_REQUIREMENTS_ROOTS TRACEABILITY_TEST_ROOTS SHELL_BATS_ROOTS
