# Runbook profile: eggnest workspace (cross-repo engine-level matching e2e; venv at repo root).

# --- 01_install_prerequisites (node/npm + landing web toolchain only) ---
PREREQ_MODE="install"
PREREQ_BANNER="Eggnest Prerequisites Installer"
BREW_FORMULAS="node:npm"
PREREQ_ENABLE_ZAP="false"
PREREQ_ENABLE_1PSA="false"
PREREQ_ENABLE_XCODE="false"
PREREQ_ENABLE_PG_INSTALL="false"
PREREQ_ENABLE_PGTAP="false"
PREREQ_EXTRA_HOOK="src/scripts/prereq_hooks/eggnest_landing_web.sh"

# --- 02_create_venv (exit-if-exists; source activation hint) ---
VENV_EXISTS_POLICY="exit"
INSTALL_VENV_TEST_CACHE="false"
ACTIVATION_HINT="source"
REQUIRE_PREREQ_SCRIPT="true"

# --- 03_load_requirements ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="false"

# --- orchestrator 04_run_all_tests_parallel (workspace quality self-run) ---
# The eggnest root is the workspace umbrella: it physically contains the five subrepos
# (classy/mailcart/matchy/runner/teller) plus their venvs and artifacts. Keep the lane set discovery-
# driven so any new tests/tNN_*.sh pointer is picked up automatically.
ORCHESTRATOR_MODE="parallel-discover"
# Empty allow-list means "run every discovered lane".
RUN_LANE_ALLOWLIST=""

# --- t02 dependency freshness: eggnest has no Postgres/teller-API lanes; binary-integrity remains in scope. ---
RUN_POSTGRES_FRESHNESS="false"
RUN_TELLER_VERSION_FRESHNESS="false"
RUN_BINARY_INTEGRITY_CHECK="true"

# --- t00 code-quality: umbrella harness code plus first-party services scripts. ---
QUALITY_TARGETS="./tests/harness ./tests/py ./services"

# --- t03 static-security + t06 python-unit: umbrella-owned harness code plus services scripts. ---
PYTHON_SRC_DIRS="./tests/harness ./tests/py ./services"
SECURITY_FAIL_ON_MEDIUM_OR_HIGHER="false"
# eggnest is an umbrella workspace; subrepos run their own AV lanes.
CLAMAV_EXCLUDE_DIR_PATTERNS="/classy(/|$) /mailcart(/|$) /matchy(/|$) /runner(/|$) /teller(/|$)"

# --- t04 traceability: scope via requirements/tests roots; strictness is built in. ---
TRACEABILITY_REQUIREMENTS_ROOTS="${RUNBOOK_REPO_ROOT}/requirements:${RUNNER_HOME}/shared/requirements/pointers/eggnest"
TRACEABILITY_TEST_ROOTS="${RUNBOOK_REPO_ROOT}/tests/sh:${RUNNER_HOME}/shared/tests/sh/pointers/eggnest"
SHELL_BATS_ROOTS="${TRACEABILITY_TEST_ROOTS}"

export PREREQ_MODE PREREQ_BANNER BREW_FORMULAS PREREQ_ENABLE_ZAP PREREQ_ENABLE_1PSA \
  PREREQ_ENABLE_XCODE PREREQ_ENABLE_PG_INSTALL PREREQ_ENABLE_PGTAP PREREQ_EXTRA_HOOK \
  VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT \
  REQUIRE_PREREQ_SCRIPT LOAD_REQUIREMENTS_BOOTSTRAP_PIP \
  ORCHESTRATOR_MODE RUN_LANE_ALLOWLIST \
  RUN_POSTGRES_FRESHNESS RUN_TELLER_VERSION_FRESHNESS RUN_BINARY_INTEGRITY_CHECK \
  QUALITY_TARGETS PYTHON_SRC_DIRS SECURITY_FAIL_ON_MEDIUM_OR_HIGHER CLAMAV_EXCLUDE_DIR_PATTERNS \
  TRACEABILITY_REQUIREMENTS_ROOTS TRACEABILITY_TEST_ROOTS SHELL_BATS_ROOTS
