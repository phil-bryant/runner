# Runbook profile: eggnest workspace (cross-repo engine-level matching e2e; venv at repo root).

# --- 02_create_venv (no 01 prereq script; exit-if-exists; source activation hint) ---
VENV_EXISTS_POLICY="exit"
INSTALL_VENV_TEST_CACHE="false"
ACTIVATION_HINT="source"
REQUIRE_PREREQ_SCRIPT="false"

# --- 03_load_requirements ---
LOAD_REQUIREMENTS_BOOTSTRAP_PIP="false"

# --- orchestrator 04_run_all_tests_parallel (workspace quality self-run) ---
# The eggnest root is the workspace umbrella: it physically contains the five subrepos
# (classy/mailcart/matchy/runner/teller) plus their venvs and artifacts. Keep the lane set discovery-
# driven so any new tests/tNN_*.sh pointer (for example an e2e pointer lane) is picked up automatically.
# AV and SAST are intentionally NOT run at this level: those lanes scan the repo root recursively and
# would sweep every subrepo (each of which already owns its own AV/SAST), so they belong to the
# subrepos, not the umbrella.
ORCHESTRATOR_MODE="parallel-discover"
# Empty allow-list means "run every discovered lane".
RUN_LANE_ALLOWLIST=""
# Quality scoring ON; lane groups mapped to eggnest's self-run lane set (generic, not teller-baked).
QUALITY_LANE_GROUPS='{"effectiveness_quality":["t00_run_code_quality_tests"],"security_runtime_quality":["t02_run_dependency_freshness_tests"]}'

# --- t02 dependency freshness: eggnest has no Postgres/teller-API/binary-integrity sub-lanes (applicability). ---
RUN_POSTGRES_FRESHNESS="false"
RUN_TELLER_VERSION_FRESHNESS="false"
RUN_BINARY_INTEGRITY_CHECK="false"

# --- t04 traceability: umbrella self-coverage of eggnest's own thin pointers only. ---
# The eggnest root physically contains the five subrepos (classy/mailcart/matchy/runner/teller),
# each of which already owns and runs its own requirements-traceability lane. FULL_COVERAGE walks the
# repo root recursively and would sweep every subrepo's sources, so it is intentionally disabled here
# (mirroring why AV/SAST are not run at the umbrella level). Coverage is scoped to eggnest's own thin
# pointer scripts via the shared pointer requirements/tests roots; numbered-tag/bullet strictness stays on.
STRICT_TRACEABILITY_FULL_COVERAGE="false"
STRICT_TRACEABILITY_NUMBERED_TAGS="true"
STRICT_TRACEABILITY_NUMBERED_BULLETS="true"
TRACEABILITY_REQUIREMENTS_ROOTS="${RUNBOOK_REPO_ROOT}/requirements:${RUNNER_HOME}/shared/requirements/pointers/eggnest"
TRACEABILITY_TEST_ROOTS="${RUNBOOK_REPO_ROOT}/tests/sh:${RUNNER_HOME}/shared/tests/sh/pointers/eggnest"
SHELL_BATS_ROOTS="${TRACEABILITY_TEST_ROOTS}"
# Require tree-sitter for non-Python function enumeration (fail loudly, never under-report).
STRICT_TRACEABILITY_TREESITTER="true"

export VENV_EXISTS_POLICY INSTALL_VENV_TEST_CACHE ACTIVATION_HINT \
  REQUIRE_PREREQ_SCRIPT LOAD_REQUIREMENTS_BOOTSTRAP_PIP \
  ORCHESTRATOR_MODE RUN_LANE_ALLOWLIST QUALITY_LANE_GROUPS \
  RUN_POSTGRES_FRESHNESS RUN_TELLER_VERSION_FRESHNESS RUN_BINARY_INTEGRITY_CHECK \
  STRICT_TRACEABILITY_FULL_COVERAGE STRICT_TRACEABILITY_NUMBERED_TAGS STRICT_TRACEABILITY_NUMBERED_BULLETS \
  TRACEABILITY_REQUIREMENTS_ROOTS TRACEABILITY_TEST_ROOTS SHELL_BATS_ROOTS STRICT_TRACEABILITY_TREESITTER
